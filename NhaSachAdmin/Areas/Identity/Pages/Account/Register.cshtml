@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<style>
    body {
        background: linear-gradient(120deg, #4facfe, #00f2fe);
    }

    .register-container {
        max-width: 420px;
        margin: 80px auto;
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .register-title {
        text-align: center;
        margin-bottom: 20px;
        font-weight: bold;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-register {
        border-radius: 10px;
        background: linear-gradient(45deg, #4facfe, #00f2fe);
        border: none;
        transition: 0.3s;
    }

    .btn-register:hover {
        opacity: 0.9;
    }

    .login-link {
        text-align: center;
        margin-top: 15px;
    }
</style>

<div class="register-container">
    <h2 class="register-title">Tạo tài khoản</h2>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Input.Email" class="form-control" placeholder="Nhập email..." />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Mật khẩu</label>
            <input asp-for="Input.Password" class="form-control" type="password" placeholder="Nhập mật khẩu..." />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Xác nhận mật khẩu</label>
            <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu..." />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="w-100 btn btn-lg btn-register">Đăng ký</button>
    </form>

    <div class="login-link">
        <p>Đã có tài khoản? <a asp-page="/Account/Login">Đăng nhập</a></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}